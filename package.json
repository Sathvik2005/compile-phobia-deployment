{
  "name": "compile-phobia",
  "version": "1.0.0",
  "description": "Full-stack GitHub analytics and repository insight tool",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "build": "npm run build:frontend",
    "build:frontend": "cd devsync-frontend && npm run build",
    "dev": "concurrently \"cd backend && npm run dev\" \"cd devsync-frontend && npm run dev\"",
    "dev:frontend": "cd devsync-frontend && npm run dev",
    "dev:backend": "node backend/server.js",
    "start": "cd backend && npm start",
    "install-all": "npm install && cd backend && npm install && cd ../devsync-frontend && npm install"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "framer-motion": "^12.38.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "vite": "^6.0.5"
  }
}
