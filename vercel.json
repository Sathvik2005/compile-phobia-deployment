{
  "version": 2,
  "installCommand": "npm install && cd backend && npm install && cd ../devsync-frontend && npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "devsync-frontend/dist",
  "framework": "vite",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
