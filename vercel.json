{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install && cd backend && npm install && cd ../devsync-frontend && npm install",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    },
    {
      "src": "/health",
      "dest": "backend/server.js"
    },
    {
      "src": "/rate-limit",
      "dest": "backend/server.js"
    },
    {
      "src": "/resolve",
      "dest": "backend/server.js"
    },
    {
      "src": "/repo",
      "dest": "backend/server.js"
    },
    {
      "src": "/repo/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/contributors",
      "dest": "backend/server.js"
    },
    {
      "src": "/contributors/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "devsync-frontend/dist/index.html",
      "status": 200
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "backend/server.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
