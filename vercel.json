{
  "version": 2,
  "installCommand": "npm install && cd backend && npm install && cd ../devsync-frontend && npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "devsync-frontend/dist",
  "framework": "vite",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/**": {
      "runtime": "nodejs18.x"
    }
  },
  "routes": [
    {
      "src": "/api(.*)",
      "dest": "/api$1"
    },
    {
      "src": "^/(?!api/)",
      "dest": "/index.html"
    }
  ]
}
